{
  "name": "mars-modular-agent-runtime",
  "version": "1.0.0",
  "private": true,
  "description": "MARS (Modular Agent Runtime System) — unified agent, memory, messaging, fabric, tasks, extensions",
  "main": "bin/mars.js",
  "type": "commonjs",
  "bin": {
    "mars": "bin/mars.js",
    "openclaw": "bin/mars.js"
  },
  "scripts": {
    "start": "node bin/mars.js chat",
    "chat": "node bin/mars.js chat",
    "bot": "node bin/mars.js bot",
    "fabric": "node bin/mars.js fabric",
    "extensions": "node bin/mars.js extensions",
    "chroma:up": "docker compose up -d",
    "chroma:down": "docker compose down"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "Tejas Singh Bhati",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^11.10.0",
    "chalk": "^4.1.2",
    "chokidar": "^5.0.0",
    "chromadb": "^1.8.1",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "discord.js": "^14.26.4",
    "dotenv": "^16.6.1",
    "mathjs": "^15.2.0",
    "node-cron": "^3.0.3",
    "node-telegram-bot-api": "^0.66.0",
    "uuid": "^9.0.1"
  }
}
