# Copy to .env — MARS (Modular Agent Runtime System)

# ── Agent (required for chat, bot /ask, fabric jobs that call Claude) ────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
AGENT_MAX_ITERATIONS=8

# ── Multi-platform bot ───────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
# Aliases also accepted: TELEGRAM_TOKEN, DISCORD_TOKEN

# ── Reactive fabric notifier (outbound) ─────────────────────────────────────
NOTIFY_PLATFORM=console
DISCORD_TOKEN=
DISCORD_NOTIFY_CHANNEL_ID=
TELEGRAM_TOKEN=
TELEGRAM_NOTIFY_CHAT_ID=

# ── Paths (defaults work if you run from package root via `mars` / `openclaw` CLI) ─
MEMORY_DB_PATH=./data/memory.db
JOB_DB_PATH=
ALLOWED_FILE_ROOT=./data

# ── ChromaDB (semantic memory) — run: npm run chroma:up ─────────────────────
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=mars_memories
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
SEMANTIC_TOP_K=5
RECENT_TURNS_LIMIT=10

# ── Scheduler timezone ───────────────────────────────────────────────────────
TZ=Asia/Kolkata
