# ─────────────────────────────────────────────────────────────────
#  OpenClaw — Cognitive Memory Substrate  |  .env.example
#  Copy this to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────

# ChromaDB server URL (default: local Docker container)
CHROMA_URL=http://localhost:8000

# SQLite database file path
MEMORY_DB_PATH=./data/memory.db

# Embedding model — Xenova/all-MiniLM-L6-v2 (local, no API key needed)
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2

# ChromaDB collection name
CHROMA_COLLECTION=openclaw_memories

# Number of semantic results to return per query
SEMANTIC_TOP_K=5

# Number of recent conversation turns to keep in context
RECENT_TURNS_LIMIT=10
